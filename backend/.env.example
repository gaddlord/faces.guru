# faces.guru backend configuration.
# Copy to .env and adjust. All values have sane defaults; nothing here is required
# to run in mock mode (which is the default, so the app runs without any models).

# Address to bind. On the Mac, bind to the Tailscale interface or 0.0.0.0.
FG_BIND=0.0.0.0:8080

# SQLite database (jobs + media metadata). Created on first run.
FG_DB=sqlite://data/facesguru.db

# Directory where generated/uploaded media is stored and served from.
FG_MEDIA_DIR=data/media

# Mock mode: when true the worker fabricates placeholder media instead of calling
# the real model servers. Set to false on the Mac once ComfyUI/LM Studio/etc. are up.
FG_MOCK=true

# Prompt-assist style. "prose" for Flux; "tags" for Pony/Illustrious/anime SDXL.
FG_PROMPT_MODE=prose

# --- Local model servers (only used when FG_MOCK=false) ---

# ComfyUI (image + video generation) — OpenAI of diffusion, runs on the Mac.
FG_COMFYUI_URL=http://127.0.0.1:8188
FG_IMAGE_CKPT=sd_xl_base_1.0.safetensors

# LM Studio (prompt-assist LLM), OpenAI-compatible endpoint.
FG_LMSTUDIO_URL=http://127.0.0.1:1234
FG_LMSTUDIO_MODEL=mistral-small-24b-instruct

# Vision model for the Describe feature (image -> prompt). MUST accept image input.
# Defaults to FG_LMSTUDIO_MODEL (text-only models will error). Known-working example:
FG_VISION_MODEL=google/gemma-4-e4b

# Face-swap microservice (InsightFace + InSwapper, ONNX/CoreML) — see README for contract.
FG_FACESWAP_URL=http://127.0.0.1:5000

# Video microservice (LTX-Video / Wan img2vid) — see README for contract.
FG_VIDEO_URL=http://127.0.0.1:5001
